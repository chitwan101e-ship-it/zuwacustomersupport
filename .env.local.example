NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ENABLE_OTP=true
NEXT_PUBLIC_ENABLE_OTP=true

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@jbcoms.com
# Same Resend keys power signup OTP and the account-approved email when staff approve a customer.

NEXT_PUBLIC_ROOT_DOMAIN=jbcoms.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Links in transactional emails use https://NEXT_PUBLIC_ROOT_DOMAIN (or override with PUBLIC_SITE_URL=https://juwabros.com)

# Optional: which business receives new signups + welcome DMs (must match public.businesses.slug).
# Server: PRIMARY_SUPPORT_BUSINESS_SLUG=juwa-bros  Client feed: NEXT_PUBLIC_PRIMARY_SUPPORT_BUSINESS_SLUG=juwa-bros
# PRIMARY_SUPPORT_BUSINESS_SLUG=juwa-bros
# NEXT_PUBLIC_PRIMARY_SUPPORT_BUSINESS_SLUG=juwa-bros

# Signups are approved automatically by default. Set to true to require staff manual approval again.
# MANUAL_SIGNUP_APPROVAL=true

# Rate limiting for signup / OTP (strongly recommended in production). Without Upstash, a per-server
# in-memory limit applies (5 signups/hour/IP by default) — add Upstash for shared limits across instances.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# RATE_LIMIT_REGISTER_MAX=8
# RATE_LIMIT_REGISTER_WINDOW=1 h

# Optional: synthetic email domain for dashboard-created support staff (default relay-staff.jbcoms)
# STAFF_AUTH_EMAIL_DOMAIN=relay-staff.jbcoms
